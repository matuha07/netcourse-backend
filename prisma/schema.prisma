generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  STUDENT
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  username    String?
  avatarUrl   String?      @map("avatar_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  enrollments Enrollment[]
  progress    Progress[]

  role        Role         @default(USER)

  @@map("users")
}

model Course {
  id          Int          @id(map: "Course_pkey") @default(autoincrement())
  title       String
  description String?
  category    String?
  enrollments Enrollment[]
  progress    Progress[]
  sections    Section[]

  @@map("courses")
}

model Section {
  id         Int      @id(map: "Section_pkey") @default(autoincrement())
  courseId   Int      @map("course_id")
  title      String
  orderIndex Int      @default(0) @map("order_index")
  lessons    Lesson[]
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "Section_course_id_fkey")

  @@map("sections")
}

model Lesson {
  id          Int          @id(map: "Lesson_pkey") @default(autoincrement())
  sectionId   Int          @map("section_id")
  title       String
  contentType ContentType? @map("content_type")
  videoUrl    String?      @map("video_url")
  textContent String?      @map("text_content")
  orderIndex  Int          @default(0) @map("order_index")
  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade, map: "Lesson_section_id_fkey")
  quizzes     Quiz[]

  @@map("lessons")
}

model Quiz {
  id        Int        @id(map: "Quiz_pkey") @default(autoincrement())
  lessonId  Int        @map("lesson_id")
  title     String
  questions Question[]
  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade, map: "Quiz_lesson_id_fkey")

  @@map("quizzes")
}

model Question {
  id           Int           @id(map: "Question_pkey") @default(autoincrement())
  quizId       Int           @map("quiz_id")
  questionText String        @map("question_text")
  questionType QuestionType? @map("question_type")
  answers      Answer[]
  quiz         Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade, map: "Question_quiz_id_fkey")

  @@map("questions")
}

model Answer {
  id         Int       @id(map: "Answer_pkey") @default(autoincrement())
  questionId Int?      @map("question_id")
  answerText String    @map("answer_text")
  isCorrect  Boolean   @default(false) @map("is_correct")
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade, map: "Answer_question_id_fkey")

  @@map("answers")
}

model Enrollment {
  id         Int      @id(map: "Enrollment_pkey") @default(autoincrement())
  userId     Int      @map("user_id")
  courseId   Int      @map("course_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "Enrollment_course_id_fkey")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Enrollment_user_id_fkey")

  @@unique([userId, courseId], map: "Enrollment_user_id_course_id_key")
  @@map("enrollments")
}

model Progress {
  id        Int            @id(map: "Progress_pkey") @default(autoincrement())
  userId    Int            @map("user_id")
  courseId  Int            @map("course_id")
  status    ProgressStatus @default(not_started)
  updatedAt DateTime       @default(now()) @map("updated_at")
  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Progress_user_id_fkey")

  @@unique([userId, courseId])
  @@map("progress")
}

model links {
  id Int @id @default(autoincrement())
  short_url String @unique
  original_url String
  created_at DateTime @default(now())
  hits Int @default(0)
}

enum ContentType {
  video
  text
  quiz
}

enum QuestionType {
  single
  multiple
  text
}

enum ProgressStatus {
  not_started
  in_progress
  completed
}
